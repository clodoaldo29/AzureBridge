# ========================================
# AZURE DEVOPS
# ========================================
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/sua-organizacao
AZURE_DEVOPS_PAT=seu-personal-access-token
AZURE_DEVOPS_PROJECT=nome-do-projeto-padrao

# ========================================
# BANCO DE DADOS LOCAL (PostgreSQL container)
# DATABASE_URL deve ser definida explicitamente para evitar problemas
# com caracteres especiais na senha.
# Formato: postgresql://USUARIO:SENHA@postgres:5432/BANCO
# Caracteres especiais na senha devem ser URL-encoded:
#   @ -> %40   # -> %23   ! -> %21   $ -> %24
# ========================================
POSTGRES_DB=azurebridge
POSTGRES_USER=azurebridge
POSTGRES_PASSWORD=escolha-uma-senha-sem-arroba
DATABASE_URL=postgresql://azurebridge:escolha-uma-senha-sem-arroba@postgres:5432/azurebridge

# ========================================
# REDIS
# ========================================
# Deixar em branco para sem senha, ou definir uma senha forte
REDIS_PASSWORD=

# ========================================
# FEATURES
# ========================================
FEATURE_ANALYTICS=true
FEATURE_REPORTS=true
FEATURE_RDA_MODULE=false
VITE_FEATURE_RDA_MODULE=false

# ========================================
# SYNC / SCHEDULER
# ========================================
ENABLE_REVISION_PERSISTENCE=false
REVISION_SYNC_MAX_ITEMS_PER_RUN=100
AUTO_SYNC_CRON_HOURLY=0 * * * *
AUTO_SYNC_CRON_DAILY=0 2 * * *
AUTO_SYNC_RUN_ON_START=false
AUTO_SYNC_RUN_ON_START_MODE=daily
AUTO_SYNC_NEW_PROJECTS=false
AUTO_SYNC_REBUILD_ACTIVE_BURNDOWN_HOURLY=true
AUTO_SYNC_REBUILD_ACTIVE_BURNDOWN_DAILY=true
AUTO_SYNC_REBUILD_ACTIVE_BURNDOWN_FULL=true

# ========================================
# FUSO HORARIO
# ========================================
TZ=America/Sao_Paulo

# ========================================
# AI (opcional)
# ========================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
